<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zzyl.admission.mapper.ResidentCheckOutMapper">

    <resultMap type="com.zzyl.admission.domain.ResidentCheckOut" id="ResidentCheckOutResult">
        <result property="id" column="id"/>
        <result property="checkOutNo" column="check_out_no"/>
        <result property="checkInId" column="check_in_id"/>
        <result property="elderName" column="elder_name"/>
        <result property="idCard" column="id_card"/>
        <result property="bedNo" column="bed_no"/>
        <result property="applyDate" column="apply_date"/>
        <result property="expectedCheckOutDate" column="expected_check_out_date"/>
        <result property="actualCheckOutDate" column="actual_check_out_date"/>
        <result property="reason" column="reason"/>
        <result property="reasonDetail" column="reason_detail"/>
        <result property="status" column="status"/>
        <result property="approver" column="approver"/>
        <result property="approveTime" column="approve_time"/>
        <result property="approveRemark" column="approve_remark"/>
        <result property="settlementAmount" column="settlement_amount"/>
        <result property="refundAmount" column="refund_amount"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectResidentCheckOutVo">
        select id, check_out_no, check_in_id, elder_name, id_card, bed_no, apply_date,
               expected_check_out_date, actual_check_out_date, reason, reason_detail, status,
               approver, approve_time, approve_remark, settlement_amount, refund_amount,
               create_by, update_by, remark, create_time, update_time
        from resident_check_out
    </sql>

    <select id="selectResidentCheckOutList" parameterType="com.zzyl.admission.domain.ResidentCheckOut" resultMap="ResidentCheckOutResult">
        <include refid="selectResidentCheckOutVo"/>
        <where>
            <if test="elderName != null and elderName != ''"> and elder_name like concat('%', #{elderName}, '%')</if>
            <if test="checkOutNo != null and checkOutNo != ''"> and check_out_no like concat('%', #{checkOutNo}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectResidentCheckOutById" parameterType="Long" resultMap="ResidentCheckOutResult">
        <include refid="selectResidentCheckOutVo"/>
        where id = #{id}
    </select>

    <insert id="insertResidentCheckOut" parameterType="com.zzyl.admission.domain.ResidentCheckOut" useGeneratedKeys="true" keyProperty="id">
        insert into resident_check_out
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="checkOutNo != null">check_out_no,</if>
            <if test="checkInId != null">check_in_id,</if>
            <if test="elderName != null">elder_name,</if>
            <if test="idCard != null">id_card,</if>
            <if test="bedNo != null">bed_no,</if>
            <if test="applyDate != null">apply_date,</if>
            <if test="expectedCheckOutDate != null">expected_check_out_date,</if>
            <if test="actualCheckOutDate != null">actual_check_out_date,</if>
            <if test="reason != null">reason,</if>
            <if test="reasonDetail != null">reason_detail,</if>
            <if test="status != null">status,</if>
            <if test="approver != null">approver,</if>
            <if test="approveTime != null">approve_time,</if>
            <if test="approveRemark != null">approve_remark,</if>
            <if test="settlementAmount != null">settlement_amount,</if>
            <if test="refundAmount != null">refund_amount,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="remark != null">remark,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="checkOutNo != null">#{checkOutNo},</if>
            <if test="checkInId != null">#{checkInId},</if>
            <if test="elderName != null">#{elderName},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="bedNo != null">#{bedNo},</if>
            <if test="applyDate != null">#{applyDate},</if>
            <if test="expectedCheckOutDate != null">#{expectedCheckOutDate},</if>
            <if test="actualCheckOutDate != null">#{actualCheckOutDate},</if>
            <if test="reason != null">#{reason},</if>
            <if test="reasonDetail != null">#{reasonDetail},</if>
            <if test="status != null">#{status},</if>
            <if test="approver != null">#{approver},</if>
            <if test="approveTime != null">#{approveTime},</if>
            <if test="approveRemark != null">#{approveRemark},</if>
            <if test="settlementAmount != null">#{settlementAmount},</if>
            <if test="refundAmount != null">#{refundAmount},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateResidentCheckOut" parameterType="com.zzyl.admission.domain.ResidentCheckOut">
        update resident_check_out
        <trim prefix="SET" suffixOverrides=",">
            <if test="elderName != null">elder_name = #{elderName},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="bedNo != null">bed_no = #{bedNo},</if>
            <if test="applyDate != null">apply_date = #{applyDate},</if>
            <if test="expectedCheckOutDate != null">expected_check_out_date = #{expectedCheckOutDate},</if>
            <if test="actualCheckOutDate != null">actual_check_out_date = #{actualCheckOutDate},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="reasonDetail != null">reason_detail = #{reasonDetail},</if>
            <if test="status != null">status = #{status},</if>
            <if test="approver != null">approver = #{approver},</if>
            <if test="approveTime != null">approve_time = #{approveTime},</if>
            <if test="approveRemark != null">approve_remark = #{approveRemark},</if>
            <if test="settlementAmount != null">settlement_amount = #{settlementAmount},</if>
            <if test="refundAmount != null">refund_amount = #{refundAmount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteResidentCheckOutById" parameterType="Long">
        delete from resident_check_out where id = #{id}
    </delete>

    <delete id="deleteResidentCheckOutByIds" parameterType="String">
        delete from resident_check_out where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
