    <sql id="selectResidentCheckInVo">
        select id, check_in_no, assessment_id, elder_name, id_card, gender, age, phone,
               nursing_level_id, nursing_level_name, nursing_plan_id, nursing_plan_name,
               building_name, room_no, bed_no, check_in_date, contract_start_date, contract_end_date,
               emergency_contact, emergency_phone, relationship, deposit, monthly_fee, handler, status,
               create_by, update_by, remark, create_time, update_time
        from resident_check_in
    </sql>

    <select id="selectResidentCheckInList" parameterType="com.zzyl.admission.domain.ResidentCheckIn" resultMap="ResidentCheckInResult">
        <include refid="selectResidentCheckInVo"/>
        <where>
            <if test="elderName != null and elderName != ''"> and elder_name like concat('%', #{elderName}, '%')</if>
            <if test="checkInNo != null and checkInNo != ''"> and check_in_no like concat('%', #{checkInNo}, '%')</if>
            <if test="bedNo != null and bedNo != ''"> and bed_no like concat('%', #{bedNo}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectCheckedInList" resultMap="ResidentCheckInResult">
        <include refid="selectResidentCheckInVo"/>
        where status = '2'
        order by check_in_date desc
    </select>

    <select id="selectResidentCheckInById" parameterType="Long" resultMap="ResidentCheckInResult">
        <include refid="selectResidentCheckInVo"/>
        where id = #{id}
    </select>

    <insert id="insertResidentCheckIn" parameterType="com.zzyl.admission.domain.ResidentCheckIn" useGeneratedKeys="true" keyProperty="id">
